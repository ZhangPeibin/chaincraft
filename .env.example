# LLM factory provider. Supported aliases today: gpt/openai/chatgpt, claude/anthropic.
CHAINCRAFT_LLM_PROVIDER=gpt

# Optional generic model/key for the selected provider. Provider-specific keys below still work.
CHAINCRAFT_LLM_MODEL=gpt-5.4
CHAINCRAFT_LLM_API_KEY=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional network proxy for regions where OpenAI/Anthropic APIs are unreachable directly.
# Clash Verge users usually want the HTTP or mixed port. Check the port in Clash Verge settings.
# Common examples:
# CHAINCRAFT_PROXY_URL=http://127.0.0.1:7890
# CHAINCRAFT_PROXY_URL=http://127.0.0.1:7897
CHAINCRAFT_PROXY_URL=
